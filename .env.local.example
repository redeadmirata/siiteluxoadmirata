# ─── Sanity ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=gvf51tpc
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-01
# Token server-side (read-only) — gerar em sanity.io/manage → API → Tokens
SANITY_API_TOKEN=

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://admirata.com.br

# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Criar em account.mapbox.com — escopo: styles:read, tiles:read
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Hero (opcional) ──────────────────────────────────────────────────────────
# Sobrescreve o vídeo de fundo do hero do Rio (fallback: /videos/hero-rio-lagoa.mp4).
# Use para apontar a um CDN no futuro.
NEXT_PUBLIC_HERO_VIDEO_SRC=

# ─── Lead Capture ─────────────────────────────────────────────────────────────
# Destino dos leads do formulário (/api/lead encaminha para cá).
# Hoje: URL do Web App do Google Apps Script (grava na planilha).
# Amanhã: n8n / Supabase / CRM — basta trocar a URL. Vazio = leads só logados.
LEAD_WEBHOOK_URL=

# ─── Revalidação (ISR) ────────────────────────────────────────────────────────
# Secret do webhook Sanity → /api/revalidate (gerar um UUID aleatório).
# IMPORTANTE: o código lê SANITY_REVALIDATE_SECRET (não REVALIDATION_SECRET).
SANITY_REVALIDATE_SECRET=
