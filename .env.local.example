# ─── Sanity ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=gvf51tpc
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-06-01
# Token server-side (read-only) — gerar em sanity.io/manage → API → Tokens
SANITY_API_TOKEN=

# ─── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://admirata.com.br

# ─── Mapbox ───────────────────────────────────────────────────────────────────
# Criar em account.mapbox.com — escopo: styles:read, tiles:read
NEXT_PUBLIC_MAPBOX_TOKEN=

# ─── Analytics ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Lead Capture ─────────────────────────────────────────────────────────────
# Webhook n8n/externo — deixar vazio até integração estar pronta
LEAD_WEBHOOK_URL=

# ─── Revalidação (ISR) ────────────────────────────────────────────────────────
# Token para chamar /api/revalidate manualmente (gerar um UUID aleatório)
REVALIDATION_SECRET=
